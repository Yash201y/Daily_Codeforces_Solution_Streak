#include <bits/stdc++.h>
using namespace std;
int main(){
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin>>t;
    while(t--){
        int n;
        cin>>n;
        int a[n];
        int count=0,count1=0;
        for(int i=0;i<n;i++){
            cin>>a[i];
        }
        for(int i=0;i<n;i++){
            if(a[i]==67){
                count1++;
            }
            for(int j=0;j<n;j++){
                if(a[i]*a[j]==67){
                    count++;
                }
            }
        }
        if(count>0){
            cout<<"YES"<<endl;
        }
        else if(count1>0){
            cout<<"YES"<<endl;
        }
        else{
            cout<<"NO"<<endl;
        }
    }
    return 0;
}
