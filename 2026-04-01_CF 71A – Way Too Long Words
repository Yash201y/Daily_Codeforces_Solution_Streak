#include <iostream>
using namespace std;
int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    int t;
    cin>>t;
    while(t--){
        string s;
        cin>>s;
        int n=s.size();
        int m=s.size()-2;
        if(n<10){
            cout<<s<<endl;
        }
        else{
            cout<<s[0]<<m<<s[s.size()-1]<<endl;
        }
    }
    return 0;
}
