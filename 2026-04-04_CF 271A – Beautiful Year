#include <iostream>
#include <bits/stdc++.h>
using namespace std;
int main(){
    int year;
    cin>>year;
    while(true){
        year++;
        
        int temp=year;
        int cnt=0;
        vector<int>Y;
        while(temp>0){
           int rem=temp%10;
           Y.push_back(rem);
           temp/=10;
        }
        for(int i=0;i<Y.size();i++){
            for(int j=i+1;j<Y.size();j++){
               if(Y[i]==Y[j]) cnt++;
            }
        }
        if(cnt==0){
            cout<<year<<endl;
            break;
        }
    }
    return 0;
}
