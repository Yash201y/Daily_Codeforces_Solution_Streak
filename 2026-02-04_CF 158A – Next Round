#include <iostream>
using namespace std;
int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    int n,k;
    int count=0;
    cin>>n>>k;
    int a[n];
    for(int i=0; i<n; i++){
        cin>>a[i];
    }
    int K=a[k-1];
    for(int j=0;j<n;j++){
        if(a[j]>=K&&a[j]>0){
            count++;
        }
    }
    cout<<count<<endl;
    return 0;
}
