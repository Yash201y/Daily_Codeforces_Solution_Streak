#include<bits/stdc++.h>
using namespace std;

int getRoot(int x){
    while(x % 2 == 0) x /= 2;
    return x;
}

int main(){
    int t;
    cin >> t;

    while(t--){
        int n;
        cin >> n;

        int a[n];
        for(int i = 0; i < n; i++){
            cin >> a[i];
        }

        // Make a sorted copy
        int b[n];
        for(int i = 0; i < n; i++){
            b[i] = a[i];
        }
        sort(b, b + n);

        // Check condition
        bool ok = true;
        for(int i = 0; i < n; i++){
            if(getRoot(a[i]) != getRoot(b[i])){
                ok = false;
                break;
            }
        }

        if(ok){
            cout << "YES" << endl;
        }
        else{
            cout << "NO" << endl;
        }
    }
    return 0;
}
